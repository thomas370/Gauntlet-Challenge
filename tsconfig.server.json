{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["server.ts", "lib/server/**/*.ts", "lib/types/**/*.ts", "lib/types.ts", "lib/session-cookie.ts"],
  "exclude": ["node_modules", ".next", "app"]
}
