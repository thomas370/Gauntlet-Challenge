STEAM_API_KEY=your_steam_web_api_key_here
JWT_SECRET=replace_me_with_a_long_random_string

# Optional — défauts pour dev local sur http://localhost:3000
STEAM_REALM=http://localhost:3000
STEAM_RETURN_URL=http://localhost:3000/api/auth/steam/callback

# Port d'écoute (Alwaysdata fournit la variable PORT en prod).
PORT=3000

# Chemin (relatif à backend/) du build static frontend que le serveur sert.
# `npm run build` dans frontend/ produit ce dossier.
FRONTEND_DIST=../frontend/out
