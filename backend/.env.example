STEAM_API_KEY=your_steam_web_api_key_here
JWT_SECRET=replace_me_with_a_long_random_string

# Optional — défauts pour dev local sur http://localhost:3000
STEAM_REALM=http://localhost:3000
STEAM_RETURN_URL=http://localhost:3000/api/auth/steam/callback

# Port d'écoute (Alwaysdata fournit la variable PORT en prod).
PORT=3000

# Build static frontend que le serveur Express expose (relatif à backend/).
FRONTEND_DIST=../frontend/out

# Fichier SQLite (créé automatiquement). Stocke l'historique des runs, joueurs, stats.
DB_PATH=./data/gauntlet.sqlite

# Twitch app — https://dev.twitch.tv/console/apps. Ajouter les deux redirect URIs :
#   http://localhost:3000/api/twitch/auth/callback
#   https://<prod-domain>/api/twitch/auth/callback
TWITCH_CLIENT_ID=your_twitch_app_client_id
TWITCH_CLIENT_SECRET=your_twitch_app_client_secret
# Optionnel — défaut = STEAM_REALM + /api/twitch/auth/callback
TWITCH_REDIRECT_URI=http://localhost:3000/api/twitch/auth/callback
