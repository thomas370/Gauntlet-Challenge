{
  "name": "gauntlet-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo: frontend (Next.js static export) + backend (Express + Socket.io). Same-origin deployment on Alwaysdata.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspace frontend --workspace backend",
    "build": "npm --workspace frontend run build",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "start": "npm --workspace backend run start",
    "typecheck": "npm --workspace backend run typecheck"
  }
}
